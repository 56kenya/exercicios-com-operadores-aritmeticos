using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace exercicio_8
{
    internal class exercicio_8
    {
        static void Main(string[] args)
        {
            double celsius;
            double fahrenheit;

            Console.Write("Insira o valor de uma temperatura em graus Celsius a ser convertida em graus Fahrenheit: ");
            celsius = double.Parse(Console.ReadLine());

            fahrenheit = (celsius * 1.8) + 32;
            Console.Write("O valor em °C inserido convertido a °F é equivalente a: " + fahrenheit);
        }
    }
}
